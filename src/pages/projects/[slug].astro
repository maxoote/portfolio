---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectDetailIsland from '../../components/islands/ProjectDetailPage';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;

// Description courte pour meta (contexte ou premiers 160 caractères)
const shortDesc = project.detailedDescription?.context?.content?.slice(0, 160) ??
  `Projet ${project.title} par Maxime Mandin.`;

// Image OG (src de l'import ES6)
const ogImageSrc = (project.image as any)?.src ?? '';

// VisualArtwork JSON-LD pour SEO
const structuredData = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  "name": project.title,
  "description": shortDesc,
  "image": ogImageSrc ? `https://mandinmaxime.vercel.app${ogImageSrc}` : undefined,
  "artMedium": project.categories?.[0] ?? "Digital Design",
  "artform": "Digital Design",
  "creator": {
    "@type": "Person",
    "name": "Maxime Mandin",
    "url": "https://mandinmaxime.vercel.app"
  }
};
---

<BaseLayout
  title={`${project.title} — Maxime Mandin`}
  description={shortDesc}
  ogImage={ogImageSrc}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <div class="min-h-dvh py-6">
    <div class="mx-auto max-w-7xl px-4 mt-16">

      <!-- Vue détail (island React pour lightbox + interactivité) -->
      <ProjectDetailIsland project={project} client:load />

      <!-- CTA contextuel en fin de page -->
      <div class="shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000,8px_8px_0_0_rgba(0,0,0,0.5)] bg-gray-300 p-4 mt-8 text-center animate-stagger-fade-in" style="animation-delay: 700ms">
        <p class="font-bold text-gray-900 mb-3">Ce projet vous intéresse ?</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href="/contact"
            class="px-6 py-2 font-bold text-white bg-red-600 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] hover:bg-red-800 hover:scale-105 hover:-translate-y-0.5 transition-all duration-200 active:scale-95"
          >
            Me contacter
          </a>
          <a
            href="/catalogue"
            class="px-6 py-2 font-bold bg-gray-200 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] hover:bg-gray-300 hover:scale-105 hover:-translate-y-0.5 transition-all duration-200 active:scale-95"
          >
            Voir tous les projets
          </a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
