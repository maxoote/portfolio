---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectDetailIsland from '../../components/islands/ProjectDetailPage';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;

const shortDesc = project.detailedDescription?.context?.content?.slice(0, 160) ??
  `Projet ${project.title} par Maxime Mandin.`;

const ogImageSrc = (project.image as any)?.src ?? '';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  "name": project.title,
  "description": shortDesc,
  "image": ogImageSrc ? `https://mandinmaxime.vercel.app${ogImageSrc}` : undefined,
  "artMedium": project.categories?.[0] ?? "Digital Design",
  "artform": "Digital Design",
  "creator": {
    "@type": "Person",
    "name": "Maxime Mandin",
    "url": "https://mandinmaxime.vercel.app"
  }
};
---

<BaseLayout
  title={`${project.title} — Maxime Mandin`}
  description={shortDesc}
  ogImage={ogImageSrc}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <div class="py-8 px-4 md:px-8">
    <div class="mx-auto max-w-4xl">

      <!-- Détail du projet -->
      <ProjectDetailIsland project={project} client:load />

      <!-- CTA contextuel -->
      <div
        class="shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000,8px_8px_0_0_rgba(0,0,0,0.5)] bg-gray-300 p-2 mt-10 animate-stagger-fade-in"
        style="animation-delay: 700ms"
      >
        <div class="mb-2 flex items-center justify-between text-white px-3 py-1.5 bg-blue-900 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000]">
          <span class="font-semibold text-xs no-select">action.exe</span>
          <span class="p-0.5 px-1.5 bg-gray-400 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] text-black text-xs no-select">✕</span>
        </div>
        <div class="shadow-[inset_2px_2px_0_0_#808080,inset_-2px_-2px_0_0_#fff] bg-white px-6 py-5 text-center">
          <p class="font-bold text-gray-900 mb-1">Ce projet vous intéresse ?</p>
          <p class="text-sm text-gray-600 mb-4">Discutons de votre projet ensemble.</p>
          <div class="flex flex-wrap gap-3 justify-center">
            <a
              href="/contact"
              class="px-6 py-2 font-bold text-white bg-red-600 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] hover:bg-red-700 transition-colors no-select active:shadow-[inset_2px_2px_0_0_#000,inset_-2px_-2px_0_0_#fff]"
            >
              Me contacter
            </a>
            <a
              href="/catalogue"
              class="px-6 py-2 font-bold bg-gray-300 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] hover:bg-gray-400 transition-colors no-select active:shadow-[inset_2px_2px_0_0_#000,inset_-2px_-2px_0_0_#fff]"
            >
              Voir tous les projets
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
