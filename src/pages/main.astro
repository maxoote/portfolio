---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import flechePng from '../assets/fleche.png';

// 6 catégories avec leur vignette (premier projet de chaque catégorie)
const categories = ["Audiovisuel", "Branding", "Photographie", "Print", "Programmation", "Web-design"] as const;

const categoryCards = categories.map(cat => {
  const projectsInCat = projects.filter(p => p.categories?.includes(cat));
  return {
    name: cat,
    count: projectsInCat.length,
    image: projectsInCat[0]?.image ?? null,
  };
});

// 3 derniers projets mis en avant (les 3 premiers du tableau)
const featuredIds = ["anna-partout", "mdn-maxime", "sth"];
const featuredProjects = featuredIds.map(id => projects.find(p => p.id === id)).filter(Boolean);
---

<BaseLayout
  title="Mon travail — Maxime Mandin"
  description="Découvrez les projets de Maxime Mandin : design graphique, branding, audiovisuel, print, photographie et développement web."
>
  <div class="min-h-dvh py-6">
    <div class="mx-auto max-w-7xl px-4">

      <!-- Section 1 : Grille de catégories -->
      <div class="shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000,8px_8px_0_0_rgba(0,0,0,0.5)] bg-gray-300 p-2 mt-16">
        <div class="mb-2 flex items-center justify-between text-white px-3 py-2 bg-blue-900 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000]">
          <span class="font-semibold text-xl no-select">Mon travail</span>
          <span class="p-1 px-2 bg-gray-400 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] no-select">✕</span>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 p-2">
          {categoryCards.map((cat, idx) => (
            <a
              href="/catalogue"
              onclick={`sessionStorage.setItem('wantedCat','${cat.name}'); return true;`}
              class="group block animate-stagger-fade-in hover:scale-105 hover:-translate-y-1 transition-all duration-200"
              style={`animation-delay: ${idx * 60}ms`}
            >
              <div class="shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] bg-gray-200 overflow-hidden aspect-square relative">
                {cat.image && (
                  <img
                    src={(cat.image as any).src ?? cat.image}
                    alt={cat.name}
                    class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
                    loading="lazy"
                  />
                )}
                <div class="absolute inset-0 bg-blue-900/70 flex flex-col items-center justify-center p-2">
                  <span class="text-white font-bold text-sm sm:text-base text-center">{cat.name}</span>
                  <span class="text-white/80 text-xs mt-1">{cat.count} projet{cat.count > 1 ? 's' : ''}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Section 2 : Mes derniers projets -->
      <div class="shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000,8px_8px_0_0_rgba(0,0,0,0.5)] bg-gray-300 p-2 mt-6">
        <div class="mb-2 flex items-center justify-between text-white px-3 py-2 bg-blue-900 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000]">
          <span class="font-semibold text-xl no-select">Mes Derniers Projets</span>
          <span class="p-1 px-2 bg-gray-400 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] no-select">✕</span>
        </div>

        <div class="flex gap-3 p-2 overflow-x-auto md:grid md:grid-cols-3 md:overflow-visible">
          {featuredProjects.map((project, idx) => project && (
            <a
              href={`/projects/${project.id}`}
              class="group block flex-shrink-0 w-64 md:flex-shrink md:w-auto animate-stagger-fade-in hover:scale-105 hover:-translate-y-1 transition-all duration-200"
              style={`animation-delay: ${idx * 80}ms`}
            >
              <div class="shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000] bg-gray-200 aspect-square relative overflow-hidden">
                <img
                  src={(project.image as any).src ?? project.image}
                  alt={project.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <div class="absolute inset-x-0 bottom-0 bg-blue-900/80 px-3 py-2">
                  <span class="text-white font-semibold text-sm">{project.title}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA Outils -->
      <a
        href="/outils"
        class="block mt-6 hover:-translate-y-1 hover:shadow-md transition-all duration-250 ease-out active:scale-95 animate-stagger-fade-in"
        style="animation-delay: 400ms"
      >
        <div class="shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000,8px_8px_0_0_rgba(0,0,0,0.5)] bg-gray-300 p-2">
          <div class="mb-2 flex items-center justify-between text-white px-3 py-2 bg-red-600 hover:bg-red-800 shadow-[inset_2px_2px_0_0_#fff,inset_-2px_-2px_0_0_#000]">
            <span class="font-semibold text-base md:text-lg no-select">Découvrir mes Outils</span>
            <Image src={flechePng} alt="Flèche" class="h-6 w-6 select-none no-select" draggable={false} />
          </div>
        </div>
      </a>

    </div>
  </div>
</BaseLayout>
