---
import { ClientRouter } from 'astro:transitions';
import MenuWindow from '../components/islands/MenuWindow';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = "Portfolio de Maxime Mandin — graphiste freelance, développeur web et créatif multimédia en Vendée et Pays de la Loire.",
  ogImage = "/og-image.png",
  canonical,
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Maxime Mandin — Graphiste Freelance" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`https://mandinmaxime.vercel.app${ogImage}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@mdn_maxime" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://mandinmaxime.vercel.app${ogImage}`} />

    <!-- JSON-LD Person + LocalBusiness -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "name": "Maxime Mandin",
            "url": "https://mandinmaxime.vercel.app",
            "jobTitle": "Graphiste Freelance & Développeur Web",
            "description": "Étudiant en BUT MMI à Laval, spécialisé en design graphique, développement web et audiovisuel.",
            "sameAs": [
              "https://www.linkedin.com/in/maxime-mandin",
              "https://www.instagram.com/mdn.maxime/",
              "https://github.com/maximemandin"
            ]
          },
          {
            "@type": "LocalBusiness",
            "name": "Maxime Mandin — Graphiste Freelance",
            "description": "Création de logos, supports print, vidéo et sites web pour TPE et associations.",
            "url": "https://mandinmaxime.vercel.app",
            "image": "https://mandinmaxime.vercel.app/og-image.png",
            "areaServed": ["Vendée", "Pays de la Loire", "Laval"],
            "priceRange": "€€"
          }
        ]
      }
    </script>

    <!-- Google Verification -->
    <meta name="google-site-verification" content="your-verification-code" />

    <!-- Vercel Analytics -->
    <script>
      import('@vercel/analytics').then(({ inject }) => inject());
    </script>

    <link rel="preload" href="/fondprojet.png" as="image" />
    <ClientRouter />
  </head>

  <body class="bg-gray-300 min-h-dvh pt-9">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-1 focus:left-1 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:underline focus:shadow-[2px_2px_0_#000]"
    >
      Aller au contenu principal
    </a>

    <header transition:persist="win95-menu">
      <MenuWindow client:load pathname={Astro.url.pathname} />
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="sr-only">
      Portfolio de Mandin Maxime — Étudiant en BUT MMI à Laval.
      Spécialisations : graphisme, web design, print, audiovisuel.
      Zone de service : Vendée, Laval, Pays de la Loire.
    </footer>
  </body>
</html>
