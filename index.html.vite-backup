<!doctype html>
<html lang="fr">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="9gYkRbxHhDkb3dpPPyAm-z32KcPb51QRjvRDG15qnms" />
    <!-- Title principal -->
    <title>Graphiste Freelance Vendée | Logo, Print, Vidéo | Maxime Mandin</title>

    <!-- Meta description principale -->
    <meta name="description" content="Graphiste freelance en Vendée spécialisé en création de logos, supports print (flyers, affiches, cartes de visite) et vidéo pour TPE/PME. Devis gratuit. Intervention Vendée, Laval et Pays de la Loire." />

    <!-- Auteur -->
    <meta name="author" content="Maxime Mandin" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical (URL absolue recommandée) -->
    <link rel="canonical" href="https://mandinmaxime.vercel.app/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content="Graphiste Freelance Vendée | Logo, Print, Vidéo | Maxime Mandin" />
    <meta property="og:description" content="Création de logo, supports print et vidéos professionnelles pour petites entreprises en Vendée et Pays de la Loire." />
    <meta property="og:url" content="https://mandinmaxime.vercel.app/" />
    <meta property="og:site_name" content="Maxime Mandin - Graphiste Freelance" />
    <meta property="og:image" content="https://mandinmaxime.vercel.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mdn_maxime" />
    <meta name="twitter:creator" content="@mdn_maxime" />
    <meta name="twitter:title" content="Graphiste Freelance Vendée | Logo, Print, Vidéo" />
    <meta name="twitter:description" content="Graphiste freelance pour TPE/PME en Vendée : logos, flyers, affiches, cartes de visite, vidéo." />
    <meta name="twitter:image" content="https://mandinmaxime.vercel.app/og-image.png" />


    <!-- Theme color (mobile) -->
    <meta name="theme-color" content="#ffffff" />

    <!-- Sitemap (optionnel) -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- JSON-LD Person (déjà bon) -->
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Person",
            "name": "Maxime Mandin",
            "url": "https://mandinmaxime.vercel.app/",
            "sameAs": [
                "https://www.linkedin.com/in/maxime-mandin/",
                "https://www.instagram.com/mdn.maxime/",
                "https://github.com/maxoote"
            ],
            "jobTitle": "Graphiste Freelance",
            "description": "Graphiste freelance en Vendée, spécialisé en création de logos, supports print et vidéos pour TPE/PME."
        }
    </script>

    <!-- JSON-LD LocalBusiness -->
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "LocalBusiness",
            "name": "Maxime Mandin - Graphiste Freelance",
            "description": "Graphiste freelance spécialisé en branding, design graphique, développement web et audiovisuel",
            "areaServed": [
                {
                    "@type": "Place",
                    "name": "Vendée"
                },
                {
                    "@type": "Place",
                    "name": "Pays de la Loire"
                },
                {
                    "@type": "Place",
                    "name": "Laval"
                }
            ],
            "url": "https://mandinmaxime.vercel.app",
            "image": "https://mandinmaxime.vercel.app/og-image.png",
            "sameAs": [
                "https://www.instagram.com/mdn.maxime/",
                "https://www.linkedin.com/in/maxime-mandin/",
                "https://github.com/maxoote"
            ],
            "priceRange": "€€"
        }
    </script>
</head>

<body>
    <div id="root"></div>
    <script type="module" src="/src/main.tsx"></script>
</body>

</html>